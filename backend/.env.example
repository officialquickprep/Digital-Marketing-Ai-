# Environment variables for AI Digital Marketing System Backend
# Rename this file to .env and fill in the actual keys

# Database Configuration
DATABASE_URL=postgresql://admin:password123@localhost:5432/digitalai_db

# Redis/Celery Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Vector DB Configuration (Pinecone)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=gcp-starter

# Core AI LLM Defaults
OPENAI_API_KEY=your_openai_api_key_here

# Meta Graph API
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_custom_webhook_verify_token
META_ACCESS_TOKEN=your_system_user_token

# Omixa AI Internal Integration
OMIXA_API_URL=https://api.omixa.ai/v1/webhook
OMIXA_AUTH_TOKEN=your_omixa_token
